# [Required] Telegram Bot API Token
BOT_TOKEN=

# [Optional] Admin user ID for /getfid command
ADMIN_UID=0

# [Optional] Bearer token for monitoring dashboard (empty = no auth)
ADMIN_TOKEN=

# [Optional] Log level: debug, info, warn, error
LOG_LEVEL=info

# [Optional] Data directory for temp files and stats
# DATA_DIR=bot_data

# [Optional] Salt for anonymized user stats (set for persistent deployments)
# STATS_SALT=

# [Optional] Monitoring dashboard listen address
MONITOR_LISTEN_ADDR=:9090
